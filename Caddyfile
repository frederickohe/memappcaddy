# Ymca Member App — Caddy entrypoint
# Container DNS names must match container_name in docker-compose files.
# TLS: Let's Encrypt (automatic). Point all *.ymemberapp.com A records at this VPS before starting.

{
	email {$CADDY_ACME_EMAIL:admin@ymemberapp.com}
}

# React app — member website + admin (../memapp-web/dist)
ymemberapp.com {
	root * /srv/www
	encode gzip
	try_files {path} /index.html
	file_server
}

# Redirect www to apex
www.ymemberapp.com {
	redir https://ymemberapp.com{uri} permanent
}

# Same build as apex; routing is hostname-based in React
admin.ymemberapp.com {
	root * /srv/www
	encode gzip
	try_files {path} /index.html
	file_server
}

api.ymemberapp.com {
	reverse_proxy memapp_backend:3090

	request_body {
		max_size 50MB
	}
}

db.ymemberapp.com {
	reverse_proxy memapp_pgadmin:80

	request_body {
		max_size 50MB
	}
}

portainer.ymemberapp.com {
	reverse_proxy memapp_portainer:9000 {
		header_up Origin {scheme}://{host}
	}

	request_body {
		max_size 50MB
	}
}
